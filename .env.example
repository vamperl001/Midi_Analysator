# GEMINI_API_KEY: Required for Gemini AI API calls (AI Studio injects at runtime)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted (AI Studio injects at runtime)
APP_URL="MY_APP_URL"

# Supabase (optional) – für PostgreSQL statt lokalem SQLite
# SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_KEY="your-supabase-anon-key"
# SUPABASE_DB_URL="postgresql://user:pass@host:5432/db"
